# Database (PostgreSQL - get from Render Dashboard)
DATABASE_URL="postgresql://user:password@host:port/database"

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET="your-jwt-secret-here"

# Admin Seed Data (for initial setup only)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="Admin@123456"
ADMIN_NAME="System Administrator"

# App
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://your-app-name.onrender.com"

# DeepSeek AI (MCP Server)
# URL to the MCP DeepSeek server (default: http://localhost:4000)
MCP_DEEPSEEK_URL="http://localhost:4000"
# Your DeepSeek API key from https://platform.deepseek.com
DEEPSEEK_API_KEY="sk-e346a357fed940f786ba675176f2cba8"
# DeepSeek API base URL
DEEPSEEK_BASE_URL="https://api.deepseek.com"
